# Dependencies
**/node_modules/
**/.pnp
.pnp.*
**/.yarn/*
!**/.yarn/patches
!**/.yarn/plugins
!**/.yarn/releases
!**/.yarn/versions

# Next.js build files
**/.next/
**/out/
**/build/

# Go build outputs
backend/main
backend/main.exe
backend/*.exe
backend/*.out
backend/*.test

# Logs and databases
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# System files
.DS_Store
Thumbs.db

# TypeScript build files
*.tsbuildinfo

# Local env secrets (keep .env since it is a development template, but ignore local overrides)
.env.local
.env.development.local
.env.test.local
.env.production.local
